---
import MainLayout from '../layouts/MainLayout.astro';
import { LeakDetectionPage } from '../components/react/pages/StandardPages';
---

<MainLayout
	title="Leak Detection in Utah | Slab, Wall, and Hidden Line Leaks"
	description="Professional leak detection in Utah to locate slab, wall, and concealed plumbing leaks early before moisture damage and costly repairs escalate."
