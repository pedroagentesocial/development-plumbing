---
import MainLayout from '../../layouts/MainLayout.astro';
import { utahCities } from '../../lib/cities';

export function getStaticPaths() {
	return utahCities.map((city) => ({
		params: { city: city.slug },
		props: { city }
	}));
}

const { city } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const relatedCities = utahCities.filter((item) => item.slug !== city.slug).slice(0, 6);
---

<MainLayout
	title={city.title}
	description={city.description}
	pathname={`/service-areas/${city.slug}`}
	serviceSchema={{ name: `Plumbing Services in ${city.name}`, description: city.description }}
>
	<main class="section-shell py-14">
		<section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-[0_10px_36px_rgba(2,24,57,0.1)] md:p-10">
			<p class="eyebrow">Utah Service Area</p>
			<h1 class="h1 mt-3">{city.h1}</h1>
			<p class="muted mt-4 max-w-3xl text-lg">{city.intro}</p>
			<p class="muted mt-4 max-w-3xl text-base">
				Our team provides emergency plumbing, same-day appointments, drain cleaning, water heater repair, leak detection, sewer line diagnostics, and commercial plumbing support throughout {city.name}.
			</p>
			<div class="mt-6 flex flex-wrap gap-2">
				<span class="chip">Emergency Plumbing</span>
				<span class="chip">Same-Day Service</span>
				<span class="chip">Drain Cleaning</span>
				<span class="chip">Water Heater</span>
				<span class="chip">Leak Detection</span>
				<span class="chip">Sewer Line</span>
			</div>
		</section>

		<section class="mt-10">
			<h2 class="h2">Nearby Utah cities we also serve</h2>
			<div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
				{relatedCities.map((item) => (
					<a
						href={`${baseUrl}service-areas/${item.slug}`}
						class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-brand-500 hover:text-brand-700"
					>
						{item.name}
					</a>
				))}
			</div>
		</section>

		<section class="mt-12 rounded-3xl border border-slate-200 bg-slate-950 p-8 text-white md:p-10">
			<h2 class="text-3xl font-extrabold">Need a plumber in {city.name} today?</h2>
			<p class="mt-3 max-w-2xl text-slate-300">
				Call now for emergency response or request same-day service. We will confirm your arrival window quickly.
			</p>
			<div class="mt-6">
				<a
					href="tel:+18015550148"
					class="inline-flex items-center justify-center rounded-2xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-[0_10px_26px_rgba(234,122,44,0.35)] transition hover:bg-accent-600"
				>
					Call now
				</a>
			</div>
		</section>
	</main>
</MainLayout>
